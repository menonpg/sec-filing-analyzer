# SEC Filing Analyzer - Environment Variables
# Copy to .env and fill in your values

# ============================================
# REQUIRED - Security
# ============================================
# Generate with: openssl rand -base64 42
SECRET_KEY=sk-your-secret-key-here

# ============================================
# REQUIRED - Database (Railway Postgres)
# ============================================
DB_HOST=your-railway-postgres-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=dify

# ============================================
# REQUIRED - Redis (Upstash or Railway)
# ============================================
# For Upstash:
REDIS_HOST=your-upstash-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
REDIS_USE_SSL=true

# For Railway Redis:
# REDIS_HOST=your-railway-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_USE_SSL=false

# ============================================
# REQUIRED - Vector Store (Qdrant Cloud)
# ============================================
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# ============================================
# REQUIRED - LLM Provider (at least one)
# ============================================
# Azure OpenAI (recommended)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# OpenAI (alternative)
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-your-key

# ============================================
# OPTIONAL - URLs (set after Railway deploy)
# ============================================
# These get auto-configured by Railway
CONSOLE_WEB_URL=https://your-app.railway.app
SERVICE_API_URL=https://your-app.railway.app
APP_WEB_URL=https://your-app.railway.app
CONSOLE_API_URL=https://your-app.railway.app
APP_API_URL=https://your-app.railway.app
CORS_ORIGINS=*

# ============================================
# OPTIONAL - SEC API Identity
# ============================================
SEC_USER_AGENT=SEC-Filing-Analyzer contact@themenonlab.com
